{
  "name": "frappe-ui-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --base=/assets/forms_pro/frontend/ && yarn copy-html-entry",
    "preview": "vite preview",
    "lint": "oxlint .",
    "typecheck": "./typecheck.sh",
    "copy-html-entry": "cp ../forms_pro/public/frontend/index.html ../forms_pro/www/forms.html",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-vue": "^0.11.11",
    "@lucide/vue": "^1.0.0",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "feather-icons": "^4.29.2",
    "frappe-ui": "^0.1.272",
    "pinia": "^3.0.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.32",
    "vue-advanced-cropper": "^2.6.2",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.2",
    "jsdom": "^29.0.2",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.4"
  }
}
